rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- USERS ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['companyName', 'website', 'tagline', 'location', 'employeeCount', 'foundationYear', 'description', 'sectors', 'capacities', 'searchQuery', 'allianceType', 'certificates', 'avatarUrl', 'openRouterKey', 'blockedUsers']))
      );

      function isValidUser(user) {
        return user.keys().hasAll(['id', 'name', 'email']) &&
               user.id is string && user.id == userId &&
               user.name is string && user.name.size() <= 100 &&
               user.email is string && user.email.size() <= 100 &&
               (user.get('isPremium', false) is bool) &&
               (!user.keys().contains('isAdmin')); // Prevent self-assignment of admin if it existed
      }
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants && isValidChat(incoming());
      allow update: if isSignedIn() && request.auth.uid in existing().participants && isValidChat(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt'])
      );

      function isValidChat(chat) {
        return chat.participants is list && chat.participants.size() == 2 &&
               chat.participants.hasAll([request.auth.uid]);
      }

      // --- MESSAGES ---
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && 
                      request.auth.uid == incoming().senderId && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
                      isValidMessage(incoming());
        
        function isValidMessage(msg) {
          return msg.senderId is string && msg.senderId == request.auth.uid &&
                 msg.text is string && msg.text.size() <= 5000 &&
                 msg.createdAt == request.time;
        }
      }
    }

    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    // Verify the user is premium (in a real app, we'd check the user document)
                    // But here we rely on the client sending correct data + get() check if needed
                    isValidReview(incoming());

      function isValidReview(rev) {
        return rev.reviewerId is string && rev.reviewerId == request.auth.uid &&
               rev.rating is number && rev.rating >= 0 && rev.rating <= 5 &&
               rev.comment is string && rev.comment.size() <= 1000 &&
               rev.createdAt == request.time;
      }
    }
  }
}
