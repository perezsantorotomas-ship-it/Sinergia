{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and company information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "companyName": { "type": "string" },
        "isPremium": { "type": "boolean" },
        "avatarUrl": { "type": "string" },
        "sector": { "type": "string" },
        "openRouterKey": { "type": "string" },
        "website": { "type": "string" },
        "tagline": { "type": "string" },
        "location": { "type": "string" },
        "employeeCount": { "type": "string" },
        "foundationYear": { "type": "string" },
        "description": { "type": "string" },
        "sectors": { "type": "array", "items": { "type": "string" } },
        "capacities": { "type": "array", "items": { "type": "object" } },
        "searchQuery": { "type": "string" },
        "allianceType": { "type": "string" },
        "certificates": { "type": "array", "items": { "type": "object" } },
        "services": { "type": "array", "items": { "type": "object" } },
        "budget": { "type": "number" },
        "objectives": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "budget": { "type": "number" }
            }
          } 
        },
        "blockedUsers": { "type": "array", "items": { "type": "string" } },
        "aiMatchingEnabled": { "type": "boolean" },
        "autoDeleteMessages": { "type": "boolean" },
        "bio": { "type": "string" },
        "visibility": { "type": "string", "enum": ["public", "connections", "private"] },
        "themeColor": { "type": "string" },
        "recoveryEmail": { "type": "string" },
        "notificationsEnabled": { "type": "boolean" },
        "emailAlertsEnabled": { "type": "boolean" }
      },
      "required": ["id", "name", "email"]
    },
    "Agreement": {
      "title": "Agreement",
      "description": "A mutual collaboration agreement between two companies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partnerIds": { "type": "array", "items": { "type": "string" } },
        "partnerNames": { "type": "array", "items": { "type": "string" } },
        "signedBy": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["pending", "signed", "terminated", "expired", "closed", "closing_pending"] },
        "agreementType": { "type": "string", "enum": ["temporary", "permanent"] },
        "duration": { "type": "string" },
        "description": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" }
            }
          } 
        },
        "totalAmount": { "type": "number" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "closingRequestedBy": { "type": "string" },
        "willCloseAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "partnerIds", "partnerNames", "signedBy", "status", "agreementType", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "desc", "read", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between two companies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chatId", "senderId", "text", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review given by a premium user to a company",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "companyId": { "type": "string" },
        "rating": { "type": "number", "minimum": 0, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "reviewerId", "companyId", "rating", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Active conversations"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages in a chat"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Company reviews and ratings"
    },
    "/agreements/{agreementId}": {
      "schema": "Agreement",
      "description": "Signed collaboration agreements"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
